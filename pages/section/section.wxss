.page { padding: 16px; padding-bottom: 60px; background: #f7f7f7; min-height: 100vh; }
.sel { background: #fff; border-radius: 12px; padding: 16px; margin-bottom: 16px; }
.sel__row { display:flex; align-items:center; justify-content:space-between; padding: 10px 0; border-bottom:1px solid #f0f0f0; }
.sel__row:last-of-type { border-bottom:0; }
.sel__label { color: #666; font-size:15px; }
.sel__val { color: #333; font-size:15px; }
.sel__inp { text-align:right; font-size:20px; font-weight:bold; width:120px; color:#FF6600; }
.sel__btn { margin-top:14px; background:#FF6600; color:#fff; border-radius:8px; font-size:16px; }

.tip { text-align:center; color:#999; padding:40px 0; font-size:14px; }

.res__card { background: linear-gradient(135deg, #FF6600, #FF8C42); border-radius:14px; padding:28px 20px; text-align:center; color:#fff; margin-bottom:16px; }
.res__score { font-size:52px; font-weight:bold; line-height:1.2; }
.res__unit { font-size:20px; margin-left:4px; }
.res__rank { font-size:16px; margin-top:10px; opacity:.92; }
.res__rank .num { font-size:24px; font-weight:bold; }
.res__same { font-size:13px; margin-top:6px; opacity:.8; }
.res__beat { font-size:14px; margin-top:10px; opacity:.95; }
.res__beat-n { font-size:22px; font-weight:bold; }

.res__dist { background:#fff; border-radius:12px; padding:16px; margin-bottom:16px; }
.dist-canvas { width:100%; height:150px; display:block; }

.res__equiv { background:#fff; border-radius:12px; padding:16px; margin-bottom:16px; }
.equiv { display:flex; flex-wrap:wrap; gap:10px; }
.equiv__col { flex:1; min-width:60px; background:#FFF7F0; border-radius:8px; padding:10px 0; text-align:center; }
.equiv__y { display:block; font-size:12px; color:#999; }
.equiv__s { display:block; font-size:20px; font-weight:bold; color:#FF6600; margin-top:4px; }
.equiv__note { display:block; font-size:11px; color:#bbb; margin-top:10px; }

.res__near { background:#fff; border-radius:12px; padding:16px; }
.sec-title { font-size:16px; font-weight:bold; color:#333; margin-bottom:12px; }

.near-table { }
.near-hd { display:flex; padding:6px 0; border-bottom:2px solid #f0f0f0; font-size:13px; color:#999; }
.near-hd__s { flex:1; }
.near-hd__r { flex:1; text-align:center; }
.near-hd__d { flex:1; text-align:right; }
.near-row { display:flex; padding:8px 0; border-bottom:1px solid #f5f5f5; font-size:14px; color:#333; }
.near-row--me { background:#FFF3E8; border-radius:6px; padding:8px 4px; font-weight:bold; }
.near-row__s { flex:1; }
.near-row__r { flex:1; text-align:center; color:#FF6600; font-weight:bold; }
.near-row__d { flex:1; text-align:right; }

.foot-tip { text-align:center; color:#bbb; font-size:12px; padding:24px 0; }
