.page { padding-bottom: 160rpx; }

.hd {
  background: linear-gradient(135deg, #ff6600 0%, #ff7834 100%);
  color: #fff; padding: 44rpx 40rpx; display: flex; align-items: center; gap: 16rpx;
  border-radius: 0 0 32rpx 32rpx; margin-bottom: 24rpx;
}
.hd__name { font-size: 40rpx; font-weight: 700; }

.tip { text-align: center; color: #999; font-size: 26rpx; padding: 40rpx; }

.major-tag { margin: 0; max-width: 100%; }

.stat-row { display: flex; gap: 16rpx; }
.stat { flex: 1; text-align: center; background: #fff6f0; border-radius: 12rpx; padding: 20rpx 8rpx; }
.stat__num { font-size: 36rpx; font-weight: 700; color: #ff6600; }
.stat__lbl { font-size: 22rpx; color: #999; margin-top: 6rpx; }
.grad-note { display: flex; align-items: center; flex-wrap: wrap; gap: 16rpx; margin-top: 18rpx; }
.tag--muted { background: #f0f0f0; color: #999; }
.grad-site { font-size: 24rpx; color: #2b86d9; }
.intro { font-size: 26rpx; color: #444; line-height: 1.7; margin-top: 20rpx; }

.row { display: flex; justify-content: space-between; align-items: center; padding: 18rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.row:last-child { border-bottom: none; }
.row__major { font-size: 28rpx; font-weight: 600; color: #111111; }
.row__sub { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.row__r { text-align: right; }
.row__score { font-size: 34rpx; font-weight: 700; color: #ff6600; }
.row__rank { font-size: 22rpx; color: #cc4d00; }

.footer {
  position: fixed; left: 0; right: 0; bottom: 0;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(247,247,247,0.96); border-top: 1rpx solid #e6e6e6;
}
.row__l { flex: 1; min-width: 0; }
