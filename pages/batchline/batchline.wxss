.page { padding:16px; padding-bottom:60px; background:#f7f7f7; min-height:100vh; }
.sel { display:flex; align-items:center; justify-content:space-between; background:#fff; border-radius:12px; padding:14px 16px; margin-bottom:16px; }
.sel__label { font-size:15px; color:#666; }
.sel__val { font-size:15px; color:#333; font-weight:bold; }

/* 历年趋势卡 */
.trend { background:#fff; border-radius:12px; padding:14px 14px 12px; margin-bottom:16px; }
.trend__hd { display:flex; align-items:center; justify-content:space-between; margin-bottom:6px; }
.trend__title { font-size:15px; font-weight:bold; color:#333; }
.trend__track { display:flex; background:#f2f2f2; border-radius:14px; padding:2px; }
.trk { font-size:12px; color:#888; padding:4px 14px; border-radius:12px; }
.trk--on { background:#FF6600; color:#fff; }
.trend__canvas { width:100%; height:170px; display:block; }
.trend__legend { display:flex; gap:18px; justify-content:center; margin-top:6px; }
.lg { display:flex; align-items:center; font-size:12px; color:#666; }
.lg__dot { width:10px; height:10px; border-radius:50%; margin-right:5px; }
.trend__note { display:block; text-align:center; color:#bbb; font-size:11px; margin-top:8px; }

.tip { text-align:center; color:#999; padding:40px 0; font-size:14px; }

.groups { display:flex; flex-wrap:wrap; gap:12px; }
.group { flex:1; min-width:160px; background:#fff; border-radius:12px; overflow:hidden; }
.group__hd { background:linear-gradient(135deg, #FF6600, #FF8C42); color:#fff; text-align:center; padding:10px; font-size:15px; font-weight:bold; }
.group__rows { padding:8px 12px; }
.brow { display:flex; justify-content:space-between; align-items:center; padding:10px 0; border-bottom:1px solid #f5f5f5; }
.brow:last-child { border-bottom:0; }
.brow__name { font-size:14px; color:#333; }
.brow__score { font-size:20px; font-weight:bold; color:#FF6600; }
.brow__unit { font-size:12px; color:#999; }

.foot-tip { text-align:center; color:#bbb; font-size:12px; padding:24px 0; }
