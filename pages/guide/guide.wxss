.page { padding:16px 24rpx 60rpx; background:#f7f7f7; min-height:100vh; }
.tabs { display:flex; background:#fff; border-radius:16rpx; padding:8rpx; margin-bottom:20rpx; }
.tabs__i { flex:1; text-align:center; padding:18rpx 0; font-size:28rpx; color:#999; border-radius:12rpx; }
.tabs__i--on { background:#FF6600; color:#fff; font-weight:700; }

.tip { text-align:center; color:#999; padding:80rpx 0; }

.art { background:#fff; border-radius:16rpx; margin-bottom:16rpx; padding:24rpx 28rpx; }
.art__hd { display:flex; align-items:center; justify-content:space-between; }
.art__title { font-size:30rpx; font-weight:600; color:#333; flex:1; }
.art__arrow { font-size:24rpx; color:#ccc; margin-left:12rpx; }
.art__body { margin-top:20rpx; padding-top:20rpx; border-top:1rpx solid #f0f0f0; }
.art__text { font-size:26rpx; color:#666; line-height:1.8; white-space:pre-wrap; }

.foot-tip { text-align:center; color:#bbb; font-size:22rpx; padding:32rpx 0; }
