<view class="page">
  <view class="card">
    <view class="sec-title">分数 → 位次换算</view>
    <view class="flex gap-20 mb-16">
      <view class="opt opt--sm {{subject==='物理类'?'opt--on':''}}" data-v="物理类" bindtap="chooseSub"><view class="opt__txt">物理类</view></view>
      <view class="opt opt--sm {{subject==='历史类'?'opt--on':''}}" data-v="历史类" bindtap="chooseSub"><view class="opt__txt">历史类</view></view>
    </view>
    <input class="score-input" type="number" value="{{score}}" bindinput="onScore" placeholder="输入分数" placeholder-style="color:#ccc;font-size:40rpx;" />
    <button class="btn btn--primary btn--lg btn--block mt-16" loading="{{loading}}" bindtap="query">查位次</button>
  </view>

  <view wx:if="{{rank}}" class="card result">
    <view class="result__label">{{score}} 分 · {{subject}} 约</view>
    <view class="result__num">{{rank}}</view>
    <view class="result__unit">位</view>
    <view class="text-xs text-muted mt-8">数据来源：{{source}}（内蒙古一分一段）</view>
  </view>
</view>
