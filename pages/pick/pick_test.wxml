<view class="page">
  <view class="form">
    <view class="mode-switch">
      <view class="mode-i" data-m="score" bindtap="switchMode">按分数</view>
      <view class="mode-i" data-m="rank" bindtap="switchMode">按位次</view>
      <view class="mode-i" data-m="lincha" bindtap="switchMode">线差法</view>
    </view>
    <view class="form__row"><text class="form__label">省份</text></view>
    <view class="form__row"><text class="form__label">科类</text></view>
    <view class="form__row"><text class="form__label">分数</text></view>
    <button bindtap="query">查询</button>
  </view>
</view>