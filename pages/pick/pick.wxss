.page { padding: 20rpx 24rpx 60rpx; background: #f5f6f8; }

/* 输入表单 */
.form {
  background: #fff; border-radius: 24rpx; padding: 8rpx 28rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); margin-bottom: 24rpx;
}
.mode-switch {
  display:flex; gap:12rpx; margin-bottom:8rpx; padding-bottom:16rpx;
  border-bottom:1rpx solid #f0f0f0;
}
.mode-i {
  flex:1; display:flex; align-items:center; justify-content:center; gap:8rpx;
  padding:16rpx 0; border-radius:14rpx;
  font-size:28rpx; color:#999; background:#f7f7f7; font-weight:500;
}
.mode-i--on { background:#e85d04; color:#fff; font-weight:700; box-shadow:0 4rpx 12rpx rgba(232,93,4,0.3); }
.form__row { display: flex; align-items: center; justify-content: space-between; height: 96rpx; }
.form__label { font-size: 28rpx; color: #444; font-weight: 500; }
.form__val { font-size: 28rpx; color: #e85d04; font-weight: 500; }
.form__input { flex: 1; text-align: right; font-size: 32rpx; color: #111; font-weight: 600; }
.form__divider { height: 1rpx; background: #f5f5f5; }

/* 位次提示 */
.rank-tip {
  margin: 0 4rpx 16rpx; padding: 16rpx 20rpx;
  background: #fff7f0; border-radius: 12rpx;
  font-size: 24rpx; color: #996600; text-align: center;
}
.rank-tip__n { color: #e85d04; font-weight: 700; font-size: 28rpx; }

/* 冲稳保胶囊 — 更大更透气 */
.caps { display: flex; gap: 14rpx; margin: 0 0 20rpx; }
.cap {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  background: #fff; border-radius: 18rpx; padding: 22rpx 0;
  border: 2rpx solid transparent; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}
.cap__n { font-size: 32rpx; font-weight: 700; color: #555; }
.cap__c { font-size: 24rpx; color: #999; margin-top: 4rpx; font-weight: 500; }
.cap--on .cap__c { color: #fff; opacity: 0.85; }
.cap--on .cap__n { color: #fff; }
.cap--chong.cap--on { background: linear-gradient(145deg, #e85d04, #ff7b2c); border-color: #e85d04; box-shadow: 0 6rpx 20rpx rgba(232,93,4,0.3); }
.cap--wen.cap--on  { background: linear-gradient(145deg, #27ae60, #2ecc71); border-color: #27ae60; box-shadow: 0 6rpx 20rpx rgba(39,174,96,0.3); }
.cap--bao.cap--on  { background: linear-gradient(145deg, #2980b9, #3498db); border-color: #2980b9; box-shadow: 0 6rpx 20rpx rgba(41,128,185,0.3); }

/* 骨架屏 */
.skel-list { padding: 8rpx 0; }
.skel { padding: 28rpx 24rpx; background: #fff; border-radius: 16rpx; margin-bottom: 12rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03); }
.skel__line { height: 20rpx; background: #e8e8e8; border-radius: 6rpx; animation: shimmer 1.5s infinite; }
.skel__line--lg { width: 55%; margin-bottom: 14rpx; }
.skel__line--md { width: 38%; margin-bottom: 14rpx; }
.skel__bar { height: 10rpx; width: 80%; background: #e8e8e8; border-radius: 5rpx; animation: shimmer 1.5s infinite; }
@keyframes shimmer {
  0% { opacity: 0.35; }
  50% { opacity: 0.75; }
  100% { opacity: 0.35; }
}

/* 列表卡 */
.list { padding: 4rpx 0; }
.sch {
  display: flex; align-items: center; gap: 16rpx;
  background: #fff; border-radius: 16rpx; padding: 28rpx 24rpx;
  margin-bottom: 12rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}
.sch-hover { background: #fafafa; }
.sch__main { flex: 1; min-width: 0; }
.sch__name { font-size: 30rpx; font-weight: 600; color: #111; }
.sch__major { font-size: 24rpx; color: #666; margin-top: 8rpx; }
.sch__row { display: flex; justify-content: space-between; align-items: center; margin-top: 12rpx; }
.sch__sc { font-size: 24rpx; color: #999; }
.sch__prob { font-size: 26rpx; font-weight: 700; }
.bar { height: 8rpx; background: #f0f0f0; border-radius: 9999rpx; margin-top: 12rpx; overflow: hidden; }
.bar__fill { height: 100%; background: linear-gradient(90deg, #e85d04, #ff9a3c); border-radius: 9999rpx; transition: width 0.5s ease; }

.sch__fav {
  flex-shrink: 0; font-size: 24rpx; color: #e85d04; font-weight: 600;
  border: 1rpx solid #e85d04; border-radius: 20rpx; padding: 10rpx 18rpx; line-height: 1;
}
.sch__fav--on { color: #bbb; border-color: #e0e0e0; }

.quota { text-align: center; font-size: 24rpx; color: #999; margin-top: 18rpx; }
.quota__n { color: #e85d04; font-weight: 700; }

.lock { background: #fff; border-radius: 16rpx; padding: 40rpx 28rpx; margin-top: 24rpx; text-align: center; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04); }
.lock__t { font-size: 30rpx; font-weight: 700; color: #333; }
.lock__s { font-size: 25rpx; color: #999; margin-top: 12rpx; }

.empty-tier { text-align: center; color: #bbb; font-size: 26rpx; padding: 60rpx 20rpx; }
.tip-empty { text-align: center; padding: 140rpx 60rpx; }
.tip-empty__icon { font-size: 100rpx; margin-bottom: 24rpx; display: block; }
.tip-empty__t { font-size: 30rpx; font-weight: 600; color: #444; margin-bottom: 8rpx; }
.tip-empty__s { font-size: 26rpx; color: #bbb; }

/* 导出 */
.exp-btn-wrap { margin-top: 36rpx; text-align: center; }
.exp-btn {
  display: inline-block; background: #fff; color: #e85d04;
  border: 2rpx solid #e85d04; border-radius: 44rpx;
  font-size: 28rpx; padding: 18rpx 52rpx; line-height: 1;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.export-canvas { position: fixed; left: -9999px; top: -9999px; }
