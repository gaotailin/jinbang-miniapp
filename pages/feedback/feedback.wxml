<view class="page">
  <view class="card">
    <view class="lbl">你的建议或问题</view>
    <textarea class="ta" value="{{content}}" bindinput="onContent" maxlength="500"
              placeholder="说说使用中遇到的问题、想要的功能…（5字以上）" placeholder-style="color:#bbb" />
    <view class="lbl">联系方式（选填）</view>
    <input class="ipt" value="{{contact}}" bindinput="onContact" placeholder="微信号 / 手机号，方便我们回复" placeholder-style="color:#bbb" />
    <button class="btn btn--gold btn--lg btn--block mt-16" bindtap="submit">提交反馈</button>
  </view>

  <view class="kefu" bindtap="copyKefu">急事可加客服微信：<text class="kefu__n">{{kefu}}</text>（点击复制）</view>
</view>
