.page { padding-bottom: 40rpx; }

/* ---- 搜索栏 ---- */
.searchbar {
  display: flex; align-items: center; gap: 16rpx;
  padding: 20rpx 24rpx; background: #fff; border-bottom: 1rpx solid #e6e6e6;
  position: sticky; top: 0; z-index: 20;
}
.searchbar__box {
  flex: 1; display: flex; align-items: center; gap: 12rpx;
  background: #f2f3f5; border-radius: 999rpx; padding: 0 24rpx; height: 72rpx;
}
.searchbar__icon { font-size: 28rpx; }
.searchbar__input { flex: 1; font-size: 28rpx; }
.searchbar__btn {
  background: #ff6600; color: #fff; font-size: 28rpx; font-weight: 600;
  padding: 0 28rpx; height: 72rpx; line-height: 72rpx; border-radius: 999rpx;
}

.subentry {
  font-size: 25rpx; color: #ff6600; background: #fff;
  padding: 20rpx 28rpx; border-bottom: 1rpx solid #f0f0f0;
}

/* ---- 门类筛选条 ---- */
.cate-bar {
  white-space: nowrap;
  padding: 20rpx 20rpx 16rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.cate-chip {
  display: inline-block;
  font-size: 26rpx; color: #666;
  padding: 10rpx 28rpx; margin-right: 16rpx;
  background: #f2f3f5; border-radius: 999rpx;
  transition: all 0.2s;
}
.cate-chip--on {
  background: #ff6600; color: #fff; font-weight: 600;
}
.cate-chip--press { opacity: 0.7; }

/* ---- 提示 ---- */
.tip { text-align: center; color: #999; font-size: 24rpx; padding: 30rpx 0 20rpx; }

/* ---- 列表 ---- */
.list { padding-top: 8rpx; }
.card.mj {
  margin: 12rpx 24rpx;
  background: #fff; border-radius: 16rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.mj-hover { background: #fafafa; }

/* ---- 卡片头 ---- */
.mj__head {
  display: flex; align-items: center; justify-content: space-between;
}
.mj__name {
  font-size: 30rpx; font-weight: 600; color: #111;
  flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.tag--gold {
  font-size: 22rpx; color: #b8860b; background: #fff8e1;
  border-radius: 6rpx; padding: 4rpx 12rpx; flex-shrink: 0; margin-left: 16rpx;
}

/* ---- 标签 ---- */
.mj__tags {
  display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 14rpx;
}
.mj__tag {
  font-size: 22rpx; color: #888; background: #f2f3f5;
  border-radius: 6rpx; padding: 4rpx 14rpx;
}

/* ---- 数据栏（就业率 + 薪酬，首屏可见）---- */
.mj__data {
  display: flex; align-items: center; gap: 32rpx; margin-top: 18rpx;
  padding-top: 16rpx; border-top: 1rpx solid #f5f5f5;
}
.mj__data-item {
  display: flex; flex-direction: column; align-items: flex-start; gap: 4rpx;
}
.mj__data-val {
  font-size: 30rpx; font-weight: 700; color: #333;
}
.mj__data-item--accent .mj__data-val { color: #ff6600; }
.mj__data-label {
  font-size: 22rpx; color: #999;
}
.mj__more {
  margin-left: auto; font-size: 24rpx; color: #cc4d00;
}

/* ---- 展开详情 ---- */
.mj__detail {
  margin-top: 18rpx; padding-top: 18rpx;
  border-top: 1rpx solid #f0f0f0;
}
.mj__d-row {
  font-size: 25rpx; color: #555; line-height: 1.8; margin-bottom: 8rpx;
}
.mj__d-k {
  display: inline-block; min-width: 120rpx; color: #999;
}
.mj__intro {
  font-size: 25rpx; color: #666; line-height: 1.8; margin-top: 8rpx;
}
.mj__empty {
  font-size: 24rpx; color: #bbb; padding: 20rpx 0; text-align: center;
}
/* 开设院校 */
.mj__schools {
  margin-top: 16rpx; padding-top: 14rpx; border-top: 1rpx dashed #eee;
}
.mj__schools .mj__d-k {
  display: block; min-width: auto; color: #e8780a; font-size: 24rpx;
  font-weight: 600; margin-bottom: 10rpx;
}
.mj__sch {
  display: flex; align-items: center; gap: 12rpx;
  padding: 12rpx 0; border-bottom: 1rpx solid #f5f5f5; font-size: 25rpx;
}
.mj__sch--press { background: #fafafa; }
.mj__sch-n { flex: 1; color: #333; }
.mj__sch-p { color: #999; font-size: 22rpx; }
.mj__sch-sc { color: #e8780a; font-weight: 600; white-space: nowrap; }
.mj__loading {
  font-size: 24rpx; color: #bbb; padding: 16rpx 0; text-align: center;
}
