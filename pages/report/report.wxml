<view class="page">

  <!-- 空状态 -->
  <empty-state wx:if="{{!hasReport}}" img="/assets/illus/empty-box.png"
               title="还没有报告" desc="完成「测一测」即可生成升学报告"
               action="去测一测" bind:action="goTest" />

  <block wx:if="{{hasReport}}">
    <!-- 概要 -->
    <view class="summary">
      <view class="summary__row">
        <text>{{meta.province}}</text>
        <text class="dot">·</text>
        <text>{{meta.subject}}</text>
      </view>
      <view class="summary__score">{{meta.score}}<text class="summary__unit">分</text></view>
    </view>

    <!-- ① 兴趣画像 -->
    <view class="card">
      <view class="sec-title">① 兴趣画像</view>
      <view class="flex flex-wrap gap-12 mb-16" wx:if="{{interest.top3}}">
        <text wx:for="{{interest.top3_names}}" wx:key="*this" class="tag tag--gold">{{interest.top3[index]}} · {{item}}</text>
      </view>

      <view wx:for="{{hexagon}}" wx:key="key" class="hex">
        <view class="hex__label">{{item.key}} {{item.name}}</view>
        <view class="bar flex-1"><view class="bar__fill bar__fill--gold" style="width:{{item.pct}}%"></view></view>
        <view class="hex__val">{{item.score}}</view>
      </view>

      <view wx:if="{{interest.guide}}" class="guide">
        <view class="guide__row"><text class="guide__k">推荐选科</text><text class="guide__v">{{interest.guide.recommended_subjects}}</text></view>
        <view class="guide__row"><text class="guide__k">适合专业</text><text class="guide__v">{{interest.guide.recommended_majors}}</text></view>
      </view>
    </view>

    <!-- ② 分数定位 -->
    <view class="card">
      <view class="sec-title">② 分数定位</view>
      <view class="rank" wx:if="{{score.user_rank}}">
        <text class="rank__num">{{score.user_rank}}</text>
        <text class="rank__unit">位（{{meta.subject}}）</text>
      </view>
      <view class="text-xs text-muted mt-8" wx:if="{{score.rank_source}}">位次来源：{{score.rank_source}}</view>
    </view>

    <!-- 冲稳保 -->
    <view class="card">
      <view class="sec-title">选校推荐（冲 / 稳 / 保）</view>

      <view class="band band--chong">
        <view class="band__head"><text class="band__name">冲</text><text class="text-xs text-muted">院校线略高于你</text></view>
        <view wx:for="{{score.recommend.chong}}" wx:key="index" class="school">
          <view class="flex justify-between items-center">
            <text class="school__name">{{item.school}}</text>
            <text wx:if="{{item.school_level}}" class="tag tag--gold">{{item.school_level}}</text>
          </view>
          <view class="school__meta">{{item.major}} · 最低 {{item.min_score}} · 位次 {{item.min_rank}}<text wx:if="{{item.prob}}" class="school__prob">录取 {{item.prob}}%</text></view>
          <view wx:if="{{item.fit_reasons.length}}" class="school__fit">★ {{item.fit_reasons}}</view>
        </view>
        <view wx:if="{{!score.recommend.chong.length}}" class="text-xs text-muted">暂无</view>
      </view>

      <view class="band band--wen">
        <view class="band__head"><text class="band__name">稳</text><text class="text-xs text-muted">把握较大</text></view>
        <view wx:for="{{score.recommend.wen}}" wx:key="index" class="school">
          <view class="flex justify-between items-center">
            <text class="school__name">{{item.school}}</text>
            <text wx:if="{{item.school_level}}" class="tag tag--gold">{{item.school_level}}</text>
          </view>
          <view class="school__meta">{{item.major}} · 最低 {{item.min_score}} · 位次 {{item.min_rank}}<text wx:if="{{item.prob}}" class="school__prob">录取 {{item.prob}}%</text></view>
          <view wx:if="{{item.fit_reasons.length}}" class="school__fit">★ {{item.fit_reasons}}</view>
        </view>
        <view wx:if="{{!score.recommend.wen.length}}" class="text-xs text-muted">暂无</view>
      </view>

      <view class="band band--bao">
        <view class="band__head"><text class="band__name">保</text><text class="text-xs text-muted">兜底稳妥</text></view>
        <view wx:for="{{score.recommend.bao}}" wx:key="index" class="school">
          <view class="flex justify-between items-center">
            <text class="school__name">{{item.school}}</text>
            <text wx:if="{{item.school_level}}" class="tag tag--gold">{{item.school_level}}</text>
          </view>
          <view class="school__meta">{{item.major}} · 最低 {{item.min_score}} · 位次 {{item.min_rank}}<text wx:if="{{item.prob}}" class="school__prob">录取 {{item.prob}}%</text></view>
          <view wx:if="{{item.fit_reasons.length}}" class="school__fit">★ {{item.fit_reasons}}</view>
        </view>
        <view wx:if="{{!score.recommend.bao.length}}" class="text-xs text-muted">暂无</view>
      </view>
    </view>

    <view class="footer-tip">数据来源 小金V4 · 全国3252校 · 仅供参考</view>
  </block>

</view>
