.page { padding-bottom: 60rpx; }

/* 一键智能填报入口 */
.ai-fill {
  display: flex; align-items: center; justify-content: space-between;
  margin: 0 24rpx 24rpx; padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #FF8C00 0%, #FF5722 100%);
  border-radius: 20rpx; color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(255,87,34,0.25);
}
.ai-fill--press { opacity: 0.92; transform: scale(0.99); }
.ai-fill__t { display: flex; align-items: center; gap: 8rpx; font-size: 30rpx; font-weight: 700; }
.ai-fill__s { font-size: 23rpx; opacity: 0.9; margin-top: 6rpx; }
.ai-fill__arrow { font-size: 44rpx; font-weight: 300; }

.hd {
  background: linear-gradient(135deg, #ff6600 0%, #ff7834 100%);
  color: #fff; padding: 44rpx 40rpx; border-radius: 0 0 32rpx 32rpx; margin-bottom: 24rpx;
}
.hd__t { font-size: 38rpx; font-weight: 700; }
.hd__s { font-size: 24rpx; opacity: 0.8; margin-top: 8rpx; }
.hd__cmp {
  display: inline-flex; align-items: center; gap: 6rpx;
  margin-top: 18rpx; font-size: 24rpx; color: #fff;
  background: rgba(255,255,255,0.22); border-radius: 9999rpx; padding: 8rpx 22rpx;
}
/* 分享按钮重置成 chip 外观 */
.hd__cmp--btn { line-height: normal; border: none; }
.hd__cmp--btn::after { border: none; }

.empty { text-align: center; padding: 140rpx 60rpx; }
.empty__icon { font-size: 110rpx; }
.empty__title { font-size: 34rpx; font-weight: 700; color: #111111; margin-top: 24rpx; }
.empty__sub { font-size: 26rpx; color: #999; margin: 12rpx 0 48rpx; }

.item { display: flex; align-items: center; justify-content: space-between; }
.item__l { flex: 1; }
.item__idx { width: 40rpx; height: 40rpx; line-height: 40rpx; text-align: center; background: #ff6600; color: #fff; border-radius: 9999rpx; font-size: 24rpx; }
.item__name { font-size: 30rpx; font-weight: 600; color: #111111; }
.item__meta { font-size: 24rpx; color: #999; margin-top: 8rpx; padding-left: 52rpx; }
.item__del { font-size: 24rpx; color: #E74C3C; padding: 10rpx 16rpx; }
.item__actions { display: flex; gap: 16rpx; align-items: center; }
.item__act { font-size: 24rpx; color: #2980B9; padding: 10rpx 8rpx; }
.list { padding: 4rpx 0; }

/* 批次分组 */
.batch { margin-bottom: 24rpx; }
.batch__hd {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 24rpx; margin: 0 24rpx 8rpx;
  background: #fff; border-radius: 12rpx; border-left: 6rpx solid #ff6600;
}
.batch__name { display: flex; align-items: center; gap: 8rpx; font-size: 28rpx; font-weight: 700; color: #333; }
.batch__icon { font-size: 24rpx; }
.batch__count { font-weight: 400; color: #999; font-size: 24rpx; }
.batch__line { font-size: 22rpx; color: #ff6600; background: #fff7f0; padding: 4rpx 12rpx; border-radius: 8rpx; }
.batch__empty { text-align: center; padding: 40rpx; font-size: 24rpx; color: #ccc; }

/* 移动弹窗 */
.move-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4); z-index: 999;
  display: flex; align-items: flex-end; justify-content: center;
}
.move-pop {
  width: 100%; background: #fff; border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
}
.move-pop__title { font-size: 30rpx; font-weight: 700; color: #333; margin-bottom: 20rpx; text-align: center; }
.move-pop__item {
  padding: 24rpx 20rpx; font-size: 28rpx; color: #333; border-bottom: 1rpx solid #f0f0f0;
}
.move-pop__item--cur { color: #ccc; }
.move-pop__cancel {
  margin-top: 16rpx; padding: 24rpx; text-align: center; font-size: 28rpx; color: #999;
  background: #f5f5f5; border-radius: 12rpx;
}
