.page { padding: 0 0 160rpx; }
.bar-top { height: 8rpx; background: #eee; }
.bar-top__fill { height: 100%; background: #ff7834; transition: width .3s; }
.prog { text-align: center; color: #999; font-size: 24rpx; padding: 24rpx 0 8rpx; }
.q__t { font-size: 34rpx; font-weight: 700; color: #111111; line-height: 1.5; margin-bottom: 24rpx; }
.q__opt { border: 2rpx solid #e6e6e6; border-radius: 16rpx; padding: 30rpx 28rpx; font-size: 30rpx; color: #333; margin-bottom: 20rpx; }
.q__opt:active { border-color: #ff6600; background: rgba(255,102,0,0.04); }

.res { background: linear-gradient(135deg,#ff6600,#2980b9); color:#fff; text-align:center; padding: 70rpx 0; border-radius: 0 0 32rpx 32rpx; margin-bottom: 24rpx; }
.res__type { font-size: 100rpx; font-weight: 800; letter-spacing: 6rpx; }
.res__label { font-size: 26rpx; opacity: .85; }
.res__majors { font-size: 30rpx; color: #ff6600; font-weight: 600; line-height: 1.7; }
.footer { position: fixed; left:0; right:0; bottom:0; padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom)); background: rgba(247,247,247,.96); border-top: 1rpx solid #e6e6e6; }
.footer--row { display:flex; gap: 16rpx; }
.q { margin-bottom: 24rpx; }
