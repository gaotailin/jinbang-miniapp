/* ===== 暖橙极简（DeepSeek 式）：白底 + 品牌橙点缀 ===== */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #ffffff;
}

/* 顶部 AI 生成标识条（审核要素，保留但做轻量化） */
.disclaimer {
  display: flex; align-items: flex-start; gap: 12rpx;
  padding: 14rpx 28rpx; background: #fff8f2;
}
.disclaimer__badge {
  flex-shrink: 0; padding: 2rpx 12rpx; margin-top: 2rpx;
  background: #ff6600; color: #fff; border-radius: 8rpx;
  font-size: 20rpx; font-weight: 600;
}
.disclaimer__text { font-size: 20rpx; color: #c9863f; line-height: 1.5; }

/* 快捷提问：横向滑动胶囊 */
.quick {
  flex-shrink: 0; white-space: nowrap;
  padding: 20rpx 0 4rpx; background: #fff;
}
.quick__row { display: inline-flex; gap: 16rpx; padding-left: 28rpx; }
.quick__pad { width: 12rpx; flex-shrink: 0; }
.quick__chip {
  flex-shrink: 0; padding: 12rpx 26rpx;
  background: #f7f8fa; color: #555; border: 1rpx solid #efefef;
  border-radius: 34rpx; font-size: 24rpx; line-height: 1.4;
}
.quick__chip:active { background: #fff3ea; color: #ff6600; border-color: #ffd9bd; }

/* 消息区 */
.msgs { flex: 1; padding: 24rpx 28rpx 0; overflow-y: auto; }
.msgs__tail { height: 24rpx; }

.msgs__empty { text-align: center; padding: 120rpx 40rpx 0; }
.msgs__empty-img { width: 260rpx; height: 190rpx; margin-bottom: 20rpx; }
.msgs__empty-text {
  font-size: 34rpx; font-weight: 600; color: #222;
  letter-spacing: 2rpx; margin-bottom: 12rpx;
}
.msgs__empty-sub { font-size: 24rpx; color: #aaa; letter-spacing: 1rpx; }
.msgs__empty-aigc {
  display: inline-block; margin-top: 28rpx; padding: 8rpx 24rpx;
  background: #fff8f2; color: #c9863f;
  border-radius: 28rpx; font-size: 22rpx;
}

.msg { margin-bottom: 28rpx; display: flex; flex-direction: column; }
.msg--user { align-items: flex-end; }
.msg--ai  { align-items: flex-start; }
.msg__bubble {
  max-width: 84%; padding: 20rpx 28rpx; border-radius: 28rpx;
  font-size: 28rpx; line-height: 1.7; word-break: break-all;
}
.msg--user .msg__bubble {
  background: #ff6600; color: #fff;
  border-bottom-right-radius: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 102, 0, 0.18);
}
.msg--ai .msg__bubble {
  background: #fff; color: #333;
  border: 1rpx solid #efefef;
  border-bottom-left-radius: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.msg__bubble--typing { padding: 14rpx 28rpx; }
.msg__note { font-size: 20rpx; color: #c9c9c9; margin-top: 8rpx; margin-left: 8rpx; }
.msg__aigc-tag {
  display: inline-block; padding: 0 12rpx; margin-bottom: 10rpx;
  background: #fff3ea; color: #ff6600; border-radius: 6rpx;
  font-size: 20rpx; line-height: 34rpx; font-weight: 500;
}

.typing-label { font-size: 22rpx; color: #bbb; margin-left: 10rpx; }
.typing-dot { color: #ffb380; font-size: 20rpx; animation: blink 1.4s infinite; margin-right: 8rpx; }
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes blink { 0%, 60%, 100% { opacity: 0.2; } 30% { opacity: 1; } }

/* 输入栏：悬浮胶囊 */
.input-bar { padding: 16rpx 24rpx; background: #fff; }
.input-bar__wrap {
  display: flex; align-items: center; gap: 12rpx;
  padding: 8rpx 8rpx 8rpx 28rpx;
  background: #fff; border: 1rpx solid #ececec; border-radius: 44rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}
.input-bar__input { flex: 1; height: 68rpx; font-size: 28rpx; color: #333; }
.input-bar__btn {
  width: 68rpx; height: 68rpx; line-height: 68rpx; flex-shrink: 0;
  background: #f0f0f0; color: #bbb; border-radius: 50%;
  font-size: 30rpx; text-align: center;
  transition: background 0.2s, color 0.2s;
}
.input-bar__btn--on {
  background: #ff6600; color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255, 102, 0, 0.3);
}
.ft-safe { height: env(safe-area-inset-bottom); background: #fff; }
