<view class="page">

  <!-- 深度合成标识（审核要求：显著说明"AI生成"） -->
  <view class="disclaimer">
    <text class="disclaimer__badge">AI生成</text>
    <text class="disclaimer__text">本页回答均为人工智能生成内容，仅供参考，不构成填报决策。请以官方数据为准。</text>
  </view>

  <!-- 快捷提问：横向滑动胶囊 -->
  <scroll-view class="quick" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="quick__row">
      <view wx:for="{{quickQuestions}}" wx:key="*this" class="quick__chip" data-q="{{item}}" bindtap="askQuick">{{item}}</view>
      <view class="quick__pad"></view>
    </view>
  </scroll-view>

  <!-- 消息列表 -->
  <scroll-view class="msgs" scroll-y scroll-into-view="msg-{{messages.length - 1}}" scroll-with-animation>
    <view wx:if="{{!messages.length}}" class="msgs__empty">
      <image class="msgs__empty-img" src="/assets/illus/ai.png" mode="aspectFit" />
      <view class="msgs__empty-text">九色鹿 AI 选校助手</view>
      <view class="msgs__empty-sub">院校 · 专业 · 分数线，随便问</view>
      <view class="msgs__empty-aigc">✦ 回答内容由 AI 生成</view>
    </view>
    <view wx:for="{{messages}}" wx:key="id" id="msg-{{index}}" class="msg {{item.role === 'user' ? 'msg--user' : 'msg--ai'}}">
      <view class="msg__bubble">
        <view wx:if="{{item.role === 'ai'}}" class="msg__aigc-tag">AI生成</view>
        <text user-select>{{item.content}}</text>
      </view>
      <view wx:if="{{item.role === 'ai'}}" class="msg__note">人工智能生成 · 仅供参考</view>
    </view>
    <view wx:if="{{loading}}" class="msg msg--ai">
      <view class="msg__bubble msg__bubble--typing">
        <text class="typing-dot">●</text><text class="typing-dot">●</text><text class="typing-dot">●</text>
        <text class="typing-label">AI生成中…</text>
      </view>
    </view>
    <view class="msgs__tail"></view>
  </scroll-view>

  <!-- 输入栏：悬浮胶囊 -->
  <view class="input-bar">
    <view class="input-bar__wrap">
      <input class="input-bar__input" value="{{input}}" bindinput="onInput" confirm-type="send"
             bindconfirm="send" placeholder="输入报考问题…" placeholder-style="color:#c2c2c2"
             disabled="{{loading}}" maxlength="200" />
      <view class="input-bar__btn {{input ? 'input-bar__btn--on' : ''}}" bindtap="send">➤</view>
    </view>
  </view>

  <view class="ft-safe"></view>
</view>
