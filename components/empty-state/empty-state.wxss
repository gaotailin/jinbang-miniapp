.es { text-align: center; padding: 110rpx 60rpx; }
.es__icon { font-size: 96rpx; line-height: 1; margin-bottom: 24rpx; }
.es__img { width: 320rpx; height: 240rpx; margin-bottom: 16rpx; }
.es__title { font-size: 30rpx; font-weight: 600; color: #333; }
.es__desc { font-size: 26rpx; color: #999; margin-top: 12rpx; line-height: 1.6; }
.es__btn {
  display: inline-block; margin-top: 32rpx;
  padding: 18rpx 56rpx; border-radius: 44rpx;
  background: linear-gradient(135deg, #e85d04, #ff7b2c);
  color: #fff; font-size: 28rpx; font-weight: 600;
}
.es__btn--press { opacity: 0.9; }
